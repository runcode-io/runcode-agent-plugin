#!/bin/sh
# runcode — plugin launcher for the RunCode CLI (macOS / Linux).
#
# The CLI itself is a static Go binary published at
# github.com/runcode-io/runcode-cli. The plugin does NOT vendor it; this small
# POSIX launcher fetches the matching binary on first use, verifies its sha256
# against the release checksums.txt, caches it, and execs it. Every later call
# runs straight from cache with no network.
#
# Resolution order:
#   1. $RUNCODE_BIN            — explicit path to a runcode binary (offline /
#                               air-gapped / "use my own build"); execed as-is.
#   2. cached binary           — ~/.cache/runcode/bin/runcode-<ver>-<os>-<arch>
#   3. verified download       — from the pinned release, then cached.
#
# Override knobs (also used by tests):
#   RUNCODE_BIN            absolute path to a binary to exec instead of resolving
#   RUNCODE_CACHE         cache root (default: ${XDG_CACHE_HOME:-~/.cache}/runcode)
#   RUNCODE_PIN_VERSION   release tag to fetch (default: bin/RUNCODE_VERSION)
#   RUNCODE_DOWNLOAD_BASE base URL for the asset + checksums.txt (default: the
#                         GitHub release-download URL for the pinned version)
#
# This launcher never evals or pipes downloaded bytes into a shell. The only
# thing it runs is a binary whose sha256 matched the release manifest.
set -eu

REPO="runcode-io/runcode-cli"
HERE=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

die() {
  echo "runcode: $*" >&2
  exit 1
}

# ── 1. explicit binary override ──────────────────────────────────────────────
if [ -n "${RUNCODE_BIN:-}" ]; then
  [ -x "${RUNCODE_BIN}" ] || die "RUNCODE_BIN=${RUNCODE_BIN} is not an executable file"
  exec "${RUNCODE_BIN}" "$@"
fi

# ── pinned version ───────────────────────────────────────────────────────────
if [ -n "${RUNCODE_PIN_VERSION:-}" ]; then
  VERSION="${RUNCODE_PIN_VERSION}"
elif [ -f "${HERE}/RUNCODE_VERSION" ]; then
  VERSION=$(tr -d ' \t\r\n' <"${HERE}/RUNCODE_VERSION")
else
  die "no pinned version (missing ${HERE}/RUNCODE_VERSION and RUNCODE_PIN_VERSION)"
fi
[ -n "${VERSION}" ] || die "pinned version is empty"

# ── os / arch (must match the release asset names) ───────────────────────────
case "$(uname -s)" in
  Linux) OS=linux ;;
  Darwin) OS=darwin ;;
  *) die "this launcher supports Linux and macOS; on Windows use runcode.cmd" ;;
esac
case "$(uname -m)" in
  x86_64 | amd64) ARCH=amd64 ;;
  aarch64 | arm64) ARCH=arm64 ;;
  *) die "unsupported architecture: $(uname -m) (only amd64 and arm64 are released)" ;;
esac

# ── 2. cached binary ─────────────────────────────────────────────────────────
CACHE_ROOT="${RUNCODE_CACHE:-${XDG_CACHE_HOME:-${HOME}/.cache}/runcode}"
BIN_DIR="${CACHE_ROOT}/bin"
BIN="${BIN_DIR}/runcode-${VERSION}-${OS}-${ARCH}"
if [ -x "${BIN}" ]; then
  exec "${BIN}" "$@"
fi

# ── 3. verified download ─────────────────────────────────────────────────────
command -v curl >/dev/null 2>&1 || die "curl is required to fetch the runcode binary; install curl and retry"

ASSET="runcode_${OS}_${ARCH}.tar.gz"
BASE="${RUNCODE_DOWNLOAD_BASE:-https://github.com/${REPO}/releases/download/${VERSION}}"

mkdir -p "${BIN_DIR}"
STAGE=$(mktemp -d "${BIN_DIR}/.dl.XXXXXX") || die "could not create staging dir under ${BIN_DIR}"
trap 'rm -rf "${STAGE}"' EXIT INT TERM

echo "runcode: fetching ${VERSION} (${OS}/${ARCH}) ..." >&2
curl -fsSL "${BASE}/${ASSET}" -o "${STAGE}/${ASSET}" || die "download failed: ${BASE}/${ASSET}"
curl -fsSL "${BASE}/checksums.txt" -o "${STAGE}/checksums.txt" || die "download failed: ${BASE}/checksums.txt"

expected=$(grep " ${ASSET}\$" "${STAGE}/checksums.txt" | awk '{print $1}')
[ -n "${expected}" ] || die "no checksum for ${ASSET} in checksums.txt"

if command -v sha256sum >/dev/null 2>&1; then
  actual=$(sha256sum "${STAGE}/${ASSET}" | awk '{print $1}')
elif command -v shasum >/dev/null 2>&1; then
  actual=$(shasum -a 256 "${STAGE}/${ASSET}" | awk '{print $1}')
else
  die "neither sha256sum nor shasum found; cannot verify the download"
fi

if [ "${actual}" != "${expected}" ]; then
  die "checksum mismatch for ${ASSET} (expected ${expected}, got ${actual}); refusing to run"
fi

tar -xzf "${STAGE}/${ASSET}" -C "${STAGE}" runcode || die "could not extract runcode from ${ASSET}"
chmod +x "${STAGE}/runcode"
# Atomic publish into the cache (same filesystem → mv is atomic). Only a
# checksum-verified binary ever reaches ${BIN}.
mv -f "${STAGE}/runcode" "${BIN}" || die "could not install verified binary to ${BIN}"

# exec replaces this process, so the EXIT trap won't fire — clean staging first.
rm -rf "${STAGE}"
exec "${BIN}" "$@"
